 ---
import type { CollectionEntry } from "astro:content";

interface Props {
  product: CollectionEntry<"products">;
}

const { product } = Astro.props;
const {
  name,
  description,
  image,
  alt,
  priceCents,
  priceText,
  sizeText,
} = product.data;

const formattedPrice =
  priceText ??
  (priceCents !== undefined
    ? new Intl.NumberFormat("en-US", {
        style: "currency",
        currency: "USD",
      }).format(priceCents / 100)
    : null);

const cardImage = image
  ?.replace(/^\/images\/products\//, "/images/product-cards/")
  .replace(/\.[^.]+$/, ".webp");
---

<article class="product-card">
  <div class="product-card__media">
    {cardImage ? (
      <img
        src={cardImage}
        alt={alt ?? name}
        width="640"
        height="480"
        loading="lazy"
        decoding="async"
      />
    ) : (
      <span>Image coming soon</span>
    )}
  </div>

  <div class="product-card__content">
    <h3>{name}</h3>
    {description && <p>{description}</p>}

    <div class="product-card__details">
      {sizeText && <p class="product-card__size">Size: {sizeText}</p>}
      {formattedPrice && <p class="product-card__price">{formattedPrice}</p>}
    </div>
  </div>
</article>

<style>
  .product-card {
    display: grid;
    grid-template-rows: auto 1fr;
    height: 100%;
    overflow: hidden;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
  }

  .product-card__media {
    display: grid;
    place-items: center;
    overflow: hidden;
    aspect-ratio: 4 / 3;
    border-bottom: 1px solid var(--color-border);
    background: var(--color-surface-cool);
  }

  .product-card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .product-card__media span {
    padding: 1rem;
    color: var(--color-muted);
    text-align: center;
  }

  .product-card__content {
    display: flex;
    flex-direction: column;
    padding: 1rem;
  }

  .product-card h3 {
    min-block-size: 3.6em;
    margin-bottom: 0.5rem;
    font-size: 1.25rem;
    line-height: 1.2;
  }

  .product-card__details {
    min-block-size: 3.25rem;
    margin-top: auto;
    padding-top: 0.75rem;
  }

  .product-card__details p + p {
    margin-top: 0.25rem;
  }

  .product-card__size {
    font-size: 0.9375rem;
  }

  .product-card__price {
    color: var(--color-text);
    font-weight: 700;
  }
</style>
