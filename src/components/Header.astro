---
import { business } from "../data/business";
import { primaryNavigation } from "../data/navigation";
import ButtonLink from "./ButtonLink.astro";
import NavigationList from "./NavigationList.astro";

const currentPath = Astro.url.pathname;
---

<header class="site-header">
  <div class="site-header__inner">
    <a href="/" class="site-name">
      {business.name}
    </a>

    <div class="site-menu site-menu--desktop">
      <div class="site-menu__content">
        <nav aria-label="Primary navigation">
          <NavigationList items={primaryNavigation} currentPath={currentPath} />
        </nav>

        <div class="site-header__actions">
          <ButtonLink href={business.phoneHref}>Call for special orders</ButtonLink>
          <ButtonLink href={business.orderUrl} external>
            Order online
          </ButtonLink>
        </div>
      </div>
    </div>

    <details class="site-menu site-menu--mobile">
      <summary>Menu</summary>

      <div class="site-menu__content">
        <nav aria-label="Primary navigation">
          <NavigationList items={primaryNavigation} currentPath={currentPath} />
        </nav>

        <div class="site-header__actions">
          <ButtonLink href={business.phoneHref}>Call for special orders</ButtonLink>
          <ButtonLink href={business.orderUrl} external>
            Order online
          </ButtonLink>
        </div>
      </div>
    </details>
  </div>
</header>
