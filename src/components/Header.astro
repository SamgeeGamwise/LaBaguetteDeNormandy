---
import BrandLogo from "./BrandLogo.astro";
import HeaderMenuContent from "./HeaderMenuContent.astro";

const currentPath = Astro.url.pathname;
---

<header class="site-header">
  <div class="site-header__inner">
    <BrandLogo class="site-logo" responsive loading="eager" />

    <div class="site-menu site-menu--desktop">
      <HeaderMenuContent currentPath={currentPath} />
    </div>

    <details class="site-menu site-menu--mobile">
      <summary aria-label="Primary navigation">
        <svg
          class="menu-toggle__icon menu-toggle__icon--menu"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path d="M5 7.25h14M5 12h14M5 16.75h14" />
        </svg>
        <svg
          class="menu-toggle__icon menu-toggle__icon--close"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path d="m6.75 6.75 10.5 10.5M17.25 6.75l-10.5 10.5" />
        </svg>
      </summary>

      <HeaderMenuContent currentPath={currentPath} />
    </details>
  </div>
</header>
