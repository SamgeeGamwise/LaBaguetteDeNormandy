---
import BrandLogo from "./BrandLogo.astro";
import HeaderMenuContent from "./HeaderMenuContent.astro";

const currentPath = Astro.url.pathname;
---

<header class="site-header">
  <div class="site-header__inner">
    <BrandLogo class="site-logo" responsive loading="eager" />

    <div class="site-menu site-menu--desktop">
      <HeaderMenuContent currentPath={currentPath} />
    </div>

    <details class="site-menu site-menu--mobile">
      <summary>
        <span class="menu-toggle__label menu-toggle__label--menu">Menu</span>
        <span class="menu-toggle__label menu-toggle__label--close">Close</span>

        <svg
          class="menu-toggle__icon menu-toggle__icon--menu"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path d="M4 7h16M4 12h16M4 17h16" />
        </svg>
        <svg
          class="menu-toggle__icon menu-toggle__icon--close"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path d="m6 6 12 12M18 6 6 18" />
        </svg>
      </summary>

      <HeaderMenuContent currentPath={currentPath} />
    </details>
  </div>
</header>
