---
interface Props {
  href: string;
  external?: boolean;
  class?: string;
}

const {
  href,
  external = false,
  class: className,
} = Astro.props;
---

<a
  class:list={["button", className]}
  href={href}
  target={external ? "_blank" : undefined}
  rel={external ? "noopener noreferrer" : undefined}
>
  <slot />
</a>
