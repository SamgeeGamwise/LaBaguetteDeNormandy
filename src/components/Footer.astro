---
import { business } from "../data/business";
import { informationNavigation, menuNavigation } from "../data/navigation";
import NavigationList from "./NavigationList.astro";

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="site-footer__inner">
    <div class="site-footer__grid">
      <section>
        <h2>{business.name}</h2>
        <p>French bakery, patisserie, and café in Parker, Colorado.</p>
        <p><a href={business.phoneHref}>Call {business.phoneDisplay}</a></p>
        <p>
          <a href={business.orderUrl} target="_blank" rel="noopener noreferrer">
            Order online
          </a>
        </p>
      </section>

      <section>
        <h2>Visit</h2>
        <address>
          {business.address.map((line) => (
            <>
              {line}<br />
            </>
          ))}
        </address>
        <p><a href="/location/">Location and directions</a></p>
        <div class="site-footer__hours">
          {business.hours.map((hours) => (
            <p>{hours}</p>
          ))}
        </div>
      </section>

      <nav aria-label="Menu links">
        <h2>Menu</h2>
        <NavigationList items={menuNavigation} />
      </nav>

      <nav aria-label="Information links">
        <h2>Information</h2>
        <NavigationList items={informationNavigation} />
      </nav>
    </div>

    <p class="site-footer__legal">© {year} {business.name}</p>
  </div>
</footer>
