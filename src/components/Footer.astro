---
import { business } from "../data/business";
import { informationNavigation, menuNavigation } from "../data/navigation";
import BrandLogo from "./BrandLogo.astro";
import NavigationList from "./NavigationList.astro";
import UtilityIcon from "./UtilityIcon.astro";

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="site-footer__inner">
    <div class="site-footer__grid">
      <div>
        <BrandLogo class="site-footer__logo" />
        <p>French bakery, patisserie, and café in Parker, Colorado.</p>
        <p>
          <a class="utility-link" href={business.phoneHref}>
            <UtilityIcon icon="phone" />
            <span>Call {business.phoneDisplay}</span>
          </a>
        </p>
        <p>
          <a class="utility-link" href={business.emailHref}>
            <UtilityIcon icon="email" />
            <span>{business.emailDisplay}</span>
          </a>
        </p>
        <p>
          <a class="utility-link" href={business.orderUrl} target="_blank" rel="noopener noreferrer">
            <UtilityIcon icon="external" />
            <span>Order online</span>
          </a>
        </p>
      </div>

      <section>
        <h2 class="utility-heading"><UtilityIcon icon="location" size="medium" /> Visit</h2>
        <address>
          {business.address.map((line) => (
            <>
              {line}<br />
            </>
          ))}
        </address>
        <p><a class="utility-link" href="/location/"><UtilityIcon icon="location" /><span>Location and directions</span></a></p>
        <div class="site-footer__hours">
          <UtilityIcon icon="hours" />
          <div>
          {business.hours.map((hours) => (
            <p>{hours}</p>
          ))}
          </div>
        </div>
      </section>

      <nav aria-label="Menu links">
        <h2>Menu</h2>
        <NavigationList items={menuNavigation} />
      </nav>

      <nav aria-label="Information links">
        <h2>Information</h2>
        <NavigationList items={informationNavigation} />
      </nav>
    </div>

    <p class="site-footer__legal">© {year} {business.name}</p>
  </div>
</footer>
