---
import BaseLayout from "../layouts/BaseLayout.astro";
import { ArrowRight } from "@lucide/astro";
---

<BaseLayout
  title="Page not found | La Baguette de Normandy"
  description="That page could not be found. Return to La Baguette de Normandy or browse the bakery menu."
  canonicalPath="/404/"
  noindex
>
  <section class="not-found shell">
    <p class="eyebrow">404 · Page not found</p>
    <h1>This one is<br /><em>off the menu.</em></h1>
    <p>The page may have moved, but the bakery is still right where you left us.</p>
    <div>
      <a class="button" href="/">Return home</a>
      <a class="text-link" href="/menu/">Browse the menu <ArrowRight aria-hidden="true" /></a>
    </div>
  </section>
</BaseLayout>
