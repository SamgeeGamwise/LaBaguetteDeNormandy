---
import { Image } from "astro:assets";
import { ArrowRight, ArrowUpRight, Award, ChefHat, Croissant } from "@lucide/astro";
import storeImage from "../assets/site/store.jpg";
import BaseLayout from "../layouts/BaseLayout.astro";
import VisitSection from "../components/VisitSection.astro";
import { business } from "../../business";

const chefSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Michael Dupont",
  jobTitle: ["Master Baker", "Chef", "Chocolatier"],
  worksFor: {
    "@type": "Bakery",
    name: business.name,
    url: business.siteUrl,
  },
};
---

<BaseLayout
  title={`Chef Michael Dupont & Our Story | ${business.name}`}
  description="Meet Chef Michael Dupont, the certified master baker, chef, and chocolatier bringing 25 years of French craft to La Baguette de Normandy in Parker, Colorado."
  canonicalPath="/about/"
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(chefSchema)} />

  <section class="about-hero">
    <div class="shell about-hero-grid">
      <div class="about-hero-copy">
        <p class="eyebrow">Our story</p>
        <h1>France taught the craft.<br /><em>Chef Dupont brings it to Parker.</em></h1>
        <p class="about-lede">
          La Baguette de Normandy is led by Chef Michael Dupont, a certified master
          baker, chef, and chocolatier with 25 years devoted to the traditions of
          French baking and pastry.
        </p>
        <div class="about-actions">
          <a class="button" href="/menu/">Taste the craft</a>
          <a class="text-link" href={business.directionsUrl}>Visit the bakery <ArrowUpRight aria-hidden="true" /></a>
        </div>
      </div>

      <figure class="about-hero-image">
        <Image
          src={storeImage}
          alt="The welcoming dining room at La Baguette de Normandy in Parker, Colorado"
          widths={[640, 900, 1200]}
          sizes="(max-width: 860px) 100vw, 46vw"
          format="webp"
          quality={86}
          loading="eager"
          fetchpriority="high"
        />
        <figcaption><span>25</span> years of craft</figcaption>
      </figure>
    </div>
  </section>

  <section class="chef-profile section" aria-labelledby="chef-heading">
    <div class="shell chef-profile-grid">
      <aside class="chef-title-card">
        <Award aria-hidden="true" />
        <p>Certified</p>
        <ul>
          <li>Master baker</li>
          <li>Chef</li>
          <li>Chocolatier</li>
        </ul>
      </aside>

      <div class="chef-profile-copy">
        <p class="eyebrow">Meet the chef</p>
        <h2 id="chef-heading">Michael Dupont</h2>
        <p class="chef-standfirst">
          At La Baguette de Normandy, the name on the door matters—but the hands
          behind the dough matter even more.
        </p>
        <div class="chef-columns">
          <p>
            Chef Dupont brought his experience from France to Parker with a simple
            purpose: to make the breads, pastries, and chocolates he knows best,
            following the methods and standards of the French artisan tradition.
          </p>
          <p>
            His range is unusual. Bread asks for patience and instinct. Pastry asks
            for precision. Chocolate asks for control. After 25 years across all
            three disciplines, Chef Dupont brings that complete point of view to
            everything made for the bakery counter.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="craft-section section" aria-labelledby="craft-heading">
    <div class="shell">
      <header class="craft-heading">
        <div>
          <p class="eyebrow eyebrow-light">One chef, three disciplines</p>
          <h2 id="craft-heading">A bakery shaped by mastery.</h2>
        </div>
        <p>
          From the first loaf of the morning to a celebration cake carried out the
          door, Chef Dupont’s training connects the entire bakery.
        </p>
      </header>

      <div class="craft-grid">
        <article>
          <Croissant aria-hidden="true" />
          <span>01</span>
          <h3>Master baker</h3>
          <p>
            Crusty baguettes, rustic loaves, and buttery viennoiseries made with the
            time, touch, and daily rhythm that traditional bread demands.
          </p>
          <a href="/menu/#breads">Explore breads <ArrowRight aria-hidden="true" /></a>
        </article>
        <article>
          <ChefHat aria-hidden="true" />
          <span>02</span>
          <h3>Chef</h3>
          <p>
            A savory side of the bakery, from quiche and filled croissants to
            sandwiches, crepes, and cafe plates for breakfast and lunch.
          </p>
          <a href="/menu/#breakfast-lunch">Explore the cafe <ArrowRight aria-hidden="true" /></a>
        </article>
        <article>
          <Award aria-hidden="true" />
          <span>03</span>
          <h3>Chocolatier</h3>
          <p>
            Elegant pastries, handmade chocolates, individual treats, and
            party-sized cakes composed with balance, detail, and a French sensibility.
          </p>
          <a href="/menu/#pastries">Explore pastries <ArrowRight aria-hidden="true" /></a>
        </article>
      </div>
    </div>
  </section>

  <section class="from-france section">
    <div class="shell from-france-grid">
      <div class="from-france-copy">
        <p class="eyebrow">From France to Colorado</p>
        <h2>A little piece of France, made fresh in Parker.</h2>
        <p>
          This is not a bakery inspired by France from a distance. La Baguette de
          Normandy was created to share the authentic taste of French bread and
          pastry with its Colorado neighbors—prepared under the leadership of a
          French craftsman who has spent a career learning the work.
        </p>
        <p>
          Come early for a warm croissant and coffee. Stop in for lunch. Choose a
          pastry for the afternoon, or let us help make a gathering feel special.
          However you visit, Chef Dupont’s craft is at the center of the experience.
        </p>
        <a class="button button-outline" href="/menu/">Browse the full menu</a>
      </div>

      <div class="bakery-collage" aria-label="A selection of La Baguette de Normandy specialties">
        <figure class="collage-large">
          <img src="/images/product-cards/breads/traditional-baguette-2.webp" alt="Traditional French baguettes" loading="lazy" />
          <figcaption>Boulangerie</figcaption>
        </figure>
        <figure>
          <img src="/images/product-cards/viennoiseries/french-butter-croissant.webp" alt="French butter croissants" loading="lazy" />
          <figcaption>Viennoiserie</figcaption>
        </figure>
        <figure>
          <img src="/images/product-cards/pastries/chocolate-eclair.webp" alt="Chocolate eclairs" loading="lazy" />
          <figcaption>Patisserie</figcaption>
        </figure>
      </div>
    </div>
  </section>

  <section class="about-quote">
    <div class="shell">
      <p>“The finest traditions of the French artisan, made here every day.”</p>
      <span>La Baguette de Normandy · Parker, Colorado</span>
    </div>
  </section>

  <VisitSection />
</BaseLayout>
