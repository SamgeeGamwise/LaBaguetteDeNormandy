---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageIntro from "../components/PageIntro.astro";
import UtilityIcon from "../components/UtilityIcon.astro";
import { business } from "../data/business";
---

<BaseLayout
  title="Contact La Baguette de Normandy | Parker, Colorado"
  description="Contact La Baguette de Normandy in Parker, Colorado, with questions about products, availability, cakes, and bakery orders."
>
  <PageIntro
    title="Contact La Baguette de Normandy"
    description="Contact the bakery with questions about products, availability, cakes, special occasions, and bakery orders."
  />

  <section>
    <h2 class="utility-heading"><UtilityIcon icon="store" size="medium" /> Bakery Contact Information</h2>

    <address class="contact-detail">
      <UtilityIcon icon="location" />
      <span>
      {business.address.map((line) => <>{line}<br /></>)}
      </span>
    </address>

    <p class="contact-detail">
      <UtilityIcon icon="phone" />
      <span>Phone: <a href={business.phoneHref}>{business.phoneDisplay}</a></span>
    </p>

    <p class="contact-detail">
      <UtilityIcon icon="email" />
      <span>Email: <a href={business.emailHref}>{business.emailDisplay}</a></span>
    </p>

    <p>{business.phoneOrderNote}</p>

    <p>
      <a class="utility-link" href={business.directionsUrl} target="_blank" rel="noopener noreferrer">
        <UtilityIcon icon="location" />
        <span>Get directions to the bakery</span>
      </a>
    </p>
  </section>

  <section>
    <h2 class="utility-heading"><UtilityIcon icon="orders" size="medium" /> Orders</h2>

    <p>
      A limited selection is available through our{" "}
      <a href={business.orderUrl} target="_blank" rel="noopener noreferrer">
        online ordering site
      </a>. Please call the bakery for all other orders.
    </p>
  </section>

  <section>
    <h2 class="utility-heading"><UtilityIcon icon="hours" size="medium" /> Bakery Hours</h2>

    {business.hours.map((hours) => <p>{hours}</p>)}

    <p>
      You can also review our <a href="/location/">location and hours</a> or{" "}
      browse the <a href="/menu/">bakery menu</a>.
    </p>
  </section>
</BaseLayout>
