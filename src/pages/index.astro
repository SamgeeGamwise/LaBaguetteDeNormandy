---
import { Image } from "astro:assets";
import { ArrowRight, ArrowUpRight, Award, Sparkles } from "@lucide/astro";
import coffeeImage from "../assets/site/coffee-and-croissants.webp";
import storeImage from "../assets/site/store.jpg";
import ProductCard from "../components/ProductCard.astro";
import VisitSection from "../components/VisitSection.astro";
import { categoryDefinitions } from "../data/categories";
import BaseLayout from "../layouts/BaseLayout.astro";
import { productsById } from "../lib/products";

const featuredIds = [
  "viennoiseries-croissant",
  "breads-traditional-baguette",
  "pastries-eclair",
  "cakes-strawberry-cake-6p",
  "savory-quiche-lorraine-bacon-and-cheese",
  "tarts-mixed-berry-tart-6p",
];

const featuredProducts = featuredIds
  .map((id) => productsById.get(id))
  .filter((product) => product !== undefined);

const cafeCategories = categoryDefinitions.filter((category) =>
  ["breakfast-lunch", "crepes", "savory", "pastries", "cakes", "breads"].includes(
    category.slug,
  ),
);
---

<BaseLayout>
  <section class="home-hero">
    <div class="shell hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">Bonjour, Parker</p>
        <h1>Butter, flour,<br /><em>and a little France.</em></h1>
        <p class="hero-intro">
          Your neighborhood French bakery, patisserie, and cafe for flaky
          viennoiseries, crusty breads, elegant cakes, and a table to enjoy them at.
        </p>
        <div class="hero-actions">
          <a class="button" href="/menu/">Explore the menu</a>
        </div>
        <div class="hero-note">
          <Sparkles aria-hidden="true" />
          <p><strong>Open from 6:30 AM</strong><br />Tuesday through Saturday</p>
        </div>
      </div>

      <figure class="hero-image-wrap">
        <Image
          src={storeImage}
          alt="The refreshed dining room inside La Baguette de Normandy, with blue cafe walls, bistro chairs, and warm wood tables"
          widths={[640, 900, 1200]}
          sizes="(max-width: 820px) 100vw, 52vw"
          format="webp"
          quality={86}
          loading="eager"
          fetchpriority="high"
        />
        <figcaption>
          <span>Come in</span>
          Our refreshed cafe has a seat for you.
        </figcaption>
      </figure>
    </div>
  </section>

  <section class="quick-facts" aria-label="Bakery highlights">
    <div class="shell quick-facts-grid">
      <p>French breads &amp; pastries</p>
      <p>Breakfast &amp; lunch</p>
      <p>Dine in or take away</p>
    </div>
  </section>

  <section class="chef-intro" aria-labelledby="chef-intro-title">
    <div class="shell chef-intro-grid">
      <div class="chef-intro-mark" aria-hidden="true"><Award /></div>
      <div>
        <p class="eyebrow">The craft behind the counter</p>
        <h2 id="chef-intro-title">25 years of French savoir-faire.</h2>
      </div>
      <div class="chef-intro-copy">
        <p>
          Every baguette, croissant, pastry, and chocolate begins with Chef Michael
          Dupont—a certified master baker, chef, and chocolatier trained in the French tradition.
        </p>
        <a class="text-link" href="/about/">Meet Chef Dupont <ArrowRight aria-hidden="true" /></a>
      </div>
    </div>
  </section>

  <section class="featured-section section" id="bakery">
    <div class="shell">
      <header class="section-heading">
        <div>
          <p class="eyebrow">At the counter</p>
          <h2>Made for the everyday<br />and the special days.</h2>
        </div>
        <div class="section-heading-side">
          <p>
            Start with a French classic, find a new favorite, or bring home enough to share.
          </p>
          <a class="text-link" href="/menu/">See the full menu <ArrowRight aria-hidden="true" /></a>
        </div>
      </header>

      <div class="featured-grid">
        {featuredProducts.map((product) => (
          <ProductCard product={product} />
        ))}
      </div>
    </div>
  </section>

  <section class="cafe-story section">
    <div class="shell cafe-story-grid">
      <figure class="cafe-image-wrap">
        <Image
          src={coffeeImage}
          alt="Two fresh croissants served with coffee at La Baguette de Normandy"
          widths={[560, 800, 1100]}
          sizes="(max-width: 820px) 100vw, 48vw"
          format="webp"
          quality={84}
          loading="lazy"
        />
        <span class="image-stamp" aria-hidden="true">Cafe<br />Parker, CO</span>
      </figure>

      <div class="cafe-story-copy">
        <p class="eyebrow">Stay a while</p>
        <h2>Come for the croissant. Stay for the cafe.</h2>
        <p>
          Sweet mornings, savory lunches, celebration cakes, and good coffee all live
          under one roof. Pull up a chair, or let us wrap something for the road.
        </p>
        <ul class="category-links" aria-label="Popular menu categories">
          {cafeCategories.map((category) => (
            <li><a href={`/menu/#${category.slug}`}>{category.shortLabel} <ArrowUpRight aria-hidden="true" /></a></li>
          ))}
        </ul>
        <a class="button button-outline" href="/menu/">Browse everything</a>
      </div>
    </div>
  </section>

  <VisitSection />
</BaseLayout>
