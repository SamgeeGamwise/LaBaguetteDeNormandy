---
import BaseLayout from "../layouts/BaseLayout.astro";
import ButtonLink from "../components/ButtonLink.astro";
import ImageHero from "../components/ImageHero.astro";
import SectionHeading from "../components/SectionHeading.astro";
import VisitSection from "../components/VisitSection.astro";
import { business } from "../data/business";
---

<BaseLayout
  title="La Baguette de Normandy | French Bakery in Parker, Colorado"
  description="Handmade breads, pastries, cakes, crepes, and breakfast from an authentic French bakery in Parker, Colorado."
  pageClass="home-page"
>
  <section class="hero">
    <div class="hero-content">
      <p class="eyebrow">Authentic French bakery + neighborhood café</p>
      <h1>Handcrafted breads, pastries, cakes, and crepes made fresh daily.</h1>
      <p class="hero-intro">
        Chef Michael Dupont brings 25 years of experience as a certified master
        baker, chef, and chocolatier to every baguette, croissant, and specialty cake.
      </p>

      <div class="hero-actions">
        <ButtonLink href={business.orderUrl} external>
          Order online
        </ButtonLink>
        <ButtonLink href="/menu/">
          Browse the menu
        </ButtonLink>
      </div>
    </div>

    <ImageHero
      src="/images/site/store.jpg"
      alt="The renovated dining area inside La Baguette de Normandy"
      width={1536}
      height={2048}
      priority
    />
  </section>

  <section class="section-surface">
    <SectionHeading
      eyebrow="Fresh from the ovens"
      title="Every visit is an invitation to taste something memorable."
    />

    <div class="feature-grid">
      <article class="feature-card">
        <h3>Special orders and celebration cakes</h3>
        <p>
          Custom cakes, petit fours, and seasonal gift boxes are made to order.
          Call or stop by to plan your next celebration.
        </p>
        <ButtonLink href="/cakes/">See cakes</ButtonLink>
      </article>

      <article class="feature-card">
        <h3>Breakfast, crepes, and warm pastries</h3>
        <p>
          Start the day with fresh croissants, savory breakfast bites, and made-to-order crepes.
        </p>
        <ButtonLink href="/breakfast/">View breakfast</ButtonLink>
      </article>

      <article class="feature-card">
        <h3>Breads, viennoiseries, and bakery classics</h3>
        <p>
          Choose from baguettes, rustic loaves, tarts, and delicate petits fours.
          Every item is handcrafted with French technique.
        </p>
        <ButtonLink href="/breads/">Shop breads</ButtonLink>
      </article>
    </div>
  </section>

  <section>
    <SectionHeading title="Why people love La Baguette de Normandy">
      <p class="home-intro">
        A little slice of France in Colorado, rooted in French artisan tradition
        and made welcoming for everyday bakery visits.
      </p>
    </SectionHeading>

    <div class="text-grid">
      <div class="feature-card">
        <h3>Master craftsman baking</h3>
        <p>
          Chef Dupont is a certified master baker, chef, and chocolatier,
          combining authentic technique with the warmth of a local bakery.
        </p>
      </div>

      <div class="feature-card">
        <h3>Bakery and café</h3>
        <p>
          Stop in for coffee and a treat, enjoy breakfast or lunch, or pick up
          a baguette, croissant, or pastry to take home.
        </p>
      </div>

      <div class="feature-card">
        <h3>Simple ordering, clear visits</h3>
        <p>
          Call ahead for custom cakes and special events, use our online ordering
          link, or visit the bakery in Parker.
        </p>
      </div>
    </div>
  </section>

  <VisitSection eyebrow="Visit us" title="Your next bakery stop in Parker." />
</BaseLayout>
